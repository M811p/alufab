# اتصال قاعدة البيانات PostgreSQL
# محلياً:   postgresql://postgres:postgres@localhost:5432/alufab
# Supabase: Project Settings → Database → Connection string (URI) — استخدم منفذ 6543 (pooler) مع ?pgbouncer=true
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/alufab"

# يُولَّد تلقائياً عند تشغيل: npm run setup
AUTH_SECRET="CHANGE_ME"

# رابط المنصة (يُستخدم في روابط دعوات الفريق)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
