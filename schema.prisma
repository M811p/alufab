datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Tenant {
  id                String             @id @default(uuid())
  name              String
  crNumber          String?
  logoUrl           String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  users             User[]
  clients           Client[]
  projects          Project[]
  inventory         InventoryItem[]
  deductionProfiles DeductionProfile[]
  invitations       Invitation[]
}

enum UserRole {
  ADMIN
  MANAGER
  ESTIMATOR
  DESIGNER
  PRODUCTION
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(DESIGNER)
  isActive  Boolean  @default(true)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// دعوات انضمام أعضاء الفريق — الرمز يُخزَّن مُجزّأ (SHA-256) ولا يُعرض إلا مرة واحدة
model Invitation {
  id          String    @id @default(uuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email       String
  role        UserRole  @default(DESIGNER)
  tokenHash   String    @unique
  invitedById String
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@unique([tenantId, email])
}

model Client {
  id          String    @id @default(uuid())
  name        String
  phone       String
  email       String?
  companyName String?
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projects    Project[]
  createdAt   DateTime  @default(now())
}

enum SystemType {
  SLIDING
  HINGED
  FIXED
  CURTAIN_WALL
}

model DeductionProfile {
  id                       String          @id @default(uuid())
  tenantId                 String
  tenant                   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  systemName               String
  systemType               SystemType      @default(SLIDING)
  frameToSashHorizontal    Float           @default(0.0)
  frameToSashVertical      Float           @default(0.0)
  mullionDeduction         Float           @default(0.0)
  transomDeduction         Float           @default(0.0)
  overlapAllowance         Float           @default(0.0)
  glassDeductionHorizontal Float           @default(0.0)
  glassDeductionVertical   Float           @default(0.0)
  hardwareFormulaRules     Json
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
  quotationItems           QuotationItem[]

  @@unique([tenantId, systemName])
}

enum ProjectStatus {
  DRAFT
  QUOTED
  APPROVED
  PRODUCTION
  INSTALLATION
  COMPLETED
}

model Project {
  id         String        @id @default(uuid())
  name       String
  status     ProjectStatus @default(DRAFT)
  tenantId   String
  tenant     Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId   String
  client     Client        @relation(fields: [clientId], references: [id])
  quotations Quotation[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model Quotation {
  id                String          @id @default(uuid())
  projectId         String
  project           Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version           Int             @default(1)
  totalMaterial     Float           @default(0.0)
  totalLabor        Float           @default(0.0)
  totalInstallation Float           @default(0.0)
  profitMargin      Float           @default(15.0)
  vatAmount         Float           @default(0.0)
  finalPrice        Float           @default(0.0)
  isApproved        Boolean         @default(false)
  items             QuotationItem[]
  invoices          Invoice[]
  bom               BOM?
  createdAt         DateTime        @default(now())
}

model QuotationItem {
  id                 String           @id @default(uuid())
  quotationId        String
  quotation          Quotation        @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  deductionProfileId String
  systemProfile      DeductionProfile @relation(fields: [deductionProfileId], references: [id])
  width              Float
  height             Float
  description        String?
  gridConfiguration  Json
  glassSpecification String
  quantity           Int              @default(1)
  calculatedCost     Float            @default(0.0)
}

model BOM {
  id          String    @id @default(uuid())
  quotationId String    @unique
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  wasteFactor Float     @default(10.0)
  items       BOMItem[]
  createdAt   DateTime  @default(now())
}

enum MaterialCategory {
  PROFILE
  GLASS
  HARDWARE
  ACCESSORY
}

model BOMItem {
  id          String               @id @default(uuid())
  bomId       String
  bom         BOM                  @relation(fields: [bomId], references: [id], onDelete: Cascade)
  category    MaterialCategory
  itemName    String
  quantity    Float
  unit        String
  unitCost    Float
  totalCost   Float
  cuttingList CuttingListElement[]
}

model CuttingListElement {
  id        String  @id @default(uuid())
  bomItemId String
  bomItem   BOMItem @relation(fields: [bomItemId], references: [id], onDelete: Cascade)
  length    Float
  count     Int
  label     String
}

model InventoryItem {
  id          String           @id @default(uuid())
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sku         String           @unique
  name        String
  category    MaterialCategory
  stockLevel  Float            @default(0.0)
  minRequired Float            @default(0.0)
  unitCost    Float            @default(0.0)
  updatedAt   DateTime         @updatedAt
}

model Invoice {
  id          String    @id @default(uuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id])
  invoiceNo   String    @unique
  amountDue   Float
  taxAmount   Float
  grandTotal  Float
  isPaid      Boolean   @default(false)
  createdAt   DateTime  @default(now())
}
